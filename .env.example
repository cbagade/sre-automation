# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Langfuse Configuration (Optional - for observability and tracing)
# Get your keys from https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# Exa API Configuration
# Get your API key from https://exa.ai
EXA_API_KEY=key
CHAINLIT_AUTH_SECRET=
CHAINLIT_USERNAME=
CHAINLIT_PASSWORD=

# Operational Signals Git Repository Configuration
# Configure these to point to your git repository containing operational signals data

# Git Repository URL (without branch)
# Example: https://raw.githubusercontent.com/your-org/operational-signals
OPS_SIGNALS_GIT_URL=https://raw.githubusercontent.com/your-org/operational-signals

# Git Branch (default: main)
OPS_SIGNALS_GIT_BRANCH=main

# Git Authentication Token (Optional - for private repositories)
# For GitHub: Create a Personal Access Token (PAT) with 'repo' scope
# For GitLab: Create a Personal Access Token with 'read_repository' scope
# For Bitbucket: Create an App Password with 'repository read' permission
OPS_SIGNALS_GIT_TOKEN=
